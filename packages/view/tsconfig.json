{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "../../config/tsbase.json",
	"compilerOptions": {
		"noEmit": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": ["./*"]
		}
	},
	"include": ["**/*"]
}
