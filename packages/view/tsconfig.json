{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "../../tsbase.json",
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": ".",
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": ["./*"]
		}
	},
	"references": [{ "path": "../lib" }],
	"include": [
		"*.ts",
		"app/**/*.ts",
		"app/**/*.tsx",
		"i18n/**/*.ts",
		"i18n/**/*.tsx"
	]
}
