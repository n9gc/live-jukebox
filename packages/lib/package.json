{
	"$schema": "https://json.schemastore.org/package",
	"private": true,
	"name": "lib",
	"version": "0.1.0",
	"license": "GPL-2.0-or-later",
	"author": "n9gc",
	"description": "函数库",
	"type": "module",
	"main": "./index.ts",
	"module": "./index.ts",
	"types": "./index.ts",
	"exports": {
		".": "./index.ts",
		"./i18n": "./i18n/index.ts",
		"./jukebox": "./jukebox/index.ts",
		"./player": "./player/index.ts",
		"./reader": "./reader/index.ts",
		"./result": "./result/index.ts",
		"./types": "./types/index.ts",
		"./util": "./util/index.ts",
		"./*": "./*.ts"
	},
	"bugs": {
		"url": "https://github.com/n9gc/live-jukebox/issues"
	},
	"homepage": "https://github.com/n9gc/live-jukebox/tree/master/packages/lib#readme",
	"repository": {
		"url": "git+https://github.com/n9gc/live-jukebox",
		"type": "git"
	},
	"scripts": {
		"prepare": "pnpm run /^prepare:.*/",
		"prepare:ts-to-zod": "make-dir dist && ts-to-zod --all",
		"prepare:i18n": "typesafe-i18n --no-watch",

		"dev:i18n": "typesafe-i18n"
	},
	"dependencies": {
		"lib": "workspace:^",

		"zod": "latest",
		"@logtape/logtape": "latest",
		"typesafe-i18n": "latest",
		"bcp-47-normalize": "^2.3.0",

		"react": "latest",
		"@types/react": "latest",
		"react-dom": "latest",
		"@types/react-dom": "latest"
	},
	"devDependencies": {
		"make-dir-cli": "latest",
		"@types/node": "latest",
		"ts-to-zod": "latest"
	}
}
