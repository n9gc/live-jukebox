{
	"$schema": "https://json.schemastore.org/package",
	"private": true,
	"name": "lib",
	"version": "0.1.0",
	"license": "GPL-2.0-or-later",
	"author": "n9gc",
	"description": "函数库",
	"type": "module",
	"main": "./lib",
	"module": "./lib",
	"types": "./lib",
	"bugs": {
		"url": "https://github.com/accurtype/monodemo/issues"
	},
	"homepage": "https://github.com/accurtype/monodemo/tree/master/packages/lib#readme",
	"repository": {
		"url": "git+https://github.com/accurtype/monodemo",
		"type": "git"
	},
	"scripts": {
		"pretest": "tsc --noEmit",
		"test": "tsx test.ts | colortape",
		"build": "tsc",
		"clear": "rimraf -g **/*.{d.ts,js}",
		"prepublishOnly": "pnpm run build",
		"postpublish": "pnpm run clear"
	},
	"files": [
		"*",
		"!tsconfig.json",
		"!**/*.ts",
		"**/*.d.ts",
		"!*.swp",
		"!pnpm-lock.yaml"
	],
	"dependencies": {},
	"devDependencies": {
		"@types/tape": "latest",
		"tape": "latest",
		"colortape": "latest"
	}
}
